{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "dev"],
      "port": 3000
    },
    {
      "name": "web-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "exec", "next", "dev"],
      "port": 3100,
      "autoPort": true
    },
    {
      "name": "admin-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "admin", "exec", "next", "dev"],
      "port": 3101,
      "autoPort": true
    }
  ]
}
