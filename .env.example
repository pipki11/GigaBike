# ─────────────────────────────────────────────────────────────
# GigaBike environment variables
# Copy to apps/web/.env.local and apps/admin/.env.local
# ─────────────────────────────────────────────────────────────

# Public Supabase project (used by both apps for anon reads)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Admin app only — server-side privileged key. NEVER expose to the web app.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Web app only — canonical public origin for robots.txt / sitemap.xml / OG URLs.
# Defaults to https://gigabike.ge if unset.
NEXT_PUBLIC_SITE_URL=https://gigabike.ge

# NOTE: If these are left unset, apps/web renders from the bundled seed data
# (packages/supabase/src/seed.ts) so the site works before Supabase is connected.
